# Database Configuration
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/study_planner

# Backend Settings
APP_ENV=dev
EMBED_MODEL_NAME=intfloat/multilingual-e5-small

# Frontend Settings (for Vite)
VITE_API_BASE_URL=http://localhost:8000

# Feature Flags
ENABLE_MEMORY=true
ENABLE_PDF=true
USE_RERANKER=false

# Optional: External API Keys (if using cloud LLMs in future)
# OPENAI_API_KEY=sk-...
